<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lo que las Mujeres Necesitan | Consulta Nacional 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --cream:    #F2EDE4;
    --cream-mid:#EAE3D8;
    --orange:   #E05A2B;
    --orange-dark: #C44D22;
    --orange-light: #F4896A;
    --navy:     #1B2B4B;
    --navy-mid: #2C3E6B;
    --navy-light: #3D5080;
    --white:    #FFFFFF;
    --text-dark: #1B2B4B;
    --text-mid:  #4A5568;
    --text-light: rgba(255,255,255,0.75);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: var(--text-dark);
    background: var(--white);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 56px;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(27,43,75,0.08);
  }
  .nav-brand {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 700;
    color: var(--orange); line-height: 1.25;
    text-decoration: none;
  }
  .nav-brand span { display: block; }
  .nav-cta {
    background: var(--orange); color: white;
    border: none; cursor: pointer;
    padding: 12px 28px; border-radius: 100px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px; font-weight: 600;
    text-decoration: none; display: inline-block;
    transition: all 0.2s;
  }
  .nav-cta:hover { background: var(--orange-dark); transform: translateY(-1px); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    background: var(--cream);
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    padding-top: 72px;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    padding: 72px 48px 72px 72px;
    display: flex; flex-direction: column; justify-content: center;
    position: relative; z-index: 2;
  }

  /* Burbuja logo */
  .bubble-logo {
    width: 220px; margin-bottom: 32px;
    position: relative;
  }
  .bubble-shape {
    background: var(--orange);
    border-radius: 48% 48% 48% 8% / 48% 48% 48% 8%;
    padding: 28px 32px 36px;
    position: relative;
  }
  .bubble-shape::after {
    content: '';
    position: absolute; bottom: -18px; left: 28px;
    width: 0; height: 0;
    border-left: 18px solid transparent;
    border-right: 6px solid transparent;
    border-top: 20px solid var(--orange);
  }
  .bubble-text {
    font-family: 'Playfair Display', serif;
    font-style: italic; font-weight: 700;
    font-size: 28px; line-height: 1.15;
    color: white; letter-spacing: -0.01em;
  }
  .bubble-impulsado {
    margin-top: 28px; display: flex; align-items: center; gap: 10px;
  }
  .bubble-impulsado p {
    font-size: 11px; color: var(--text-mid);
    font-weight: 400; margin-bottom: 4px;
  }
  .wgh-badge {
    display: flex; align-items: center; gap: 8px;
  }
  .wgh-icon {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--navy-mid);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .wgh-icon svg { width: 16px; height: 16px; fill: white; }
  .wgh-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; font-weight: 700; color: var(--navy);
    letter-spacing: 0.03em; line-height: 1.2;
  }
  .wgh-name span { font-weight: 400; display: block; font-size: 10px; color: var(--text-mid); }

  /* Pill badge */
  .pill-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(224,90,43,0.1); border: 1px solid rgba(224,90,43,0.25);
    padding: 8px 18px; border-radius: 100px;
    font-size: 13px; font-weight: 500; color: var(--orange);
    margin: 36px 0 24px; width: fit-content;
  }
  .pill-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--orange); animation: blink 1.8s infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .hero-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 4vw, 58px);
    font-weight: 900; line-height: 1.08;
    color: var(--navy); margin-bottom: 0;
    letter-spacing: -0.02em;
  }
  .hero-heading .accent { color: var(--orange); font-style: italic; }

  .hero-actions {
    display: flex; gap: 14px; flex-wrap: wrap; margin-top: 40px;
  }
  .btn-primary {
    background: var(--orange); color: white;
    padding: 16px 36px; border-radius: 100px; border: none; cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 700;
    text-decoration: none; display: inline-block;
    transition: all 0.22s;
    box-shadow: 0 4px 20px rgba(224,90,43,0.35);
  }
  .btn-primary:hover { background: var(--orange-dark); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(224,90,43,0.45); }

  .btn-outline {
    background: transparent; color: var(--navy);
    border: 1.5px solid rgba(27,43,75,0.3);
    padding: 16px 36px; border-radius: 100px; cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 600;
    text-decoration: none; display: inline-block;
    transition: all 0.22s;
  }
  .btn-outline:hover { border-color: var(--navy); background: rgba(27,43,75,0.05); }

  .hero-meta {
    display: flex; gap: 8px; flex-wrap: wrap; margin-top: 24px;
  }
  .meta-pill {
    background: rgba(27,43,75,0.07); border-radius: 100px;
    padding: 5px 14px; font-size: 12px; color: var(--text-mid); font-weight: 500;
  }

  /* Hero right – foto */
  .hero-right {
    position: relative; overflow: hidden;
    min-height: 500px;
    max-width: 420px;
    margin-left: auto;
  }
  .hero-right img {
    width: 100%; height: 100%; object-fit: cover;
    object-position: center top;
  }
  .hero-right-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to right, var(--cream) 0%, transparent 15%);
  }

  /* ── ABOUT SECTION (dark) ── */
  .about-section {
    background: var(--navy);
    padding: 96px 72px;
    position: relative; overflow: hidden;
  }
  .about-section::before {
    content: '';
    position: absolute; top: -200px; right: -200px;
    width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, rgba(44,62,107,0.8) 0%, transparent 70%);
    pointer-events: none;
  }

  .about-overline {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.45); font-weight: 600;
    text-align: center; margin-bottom: 20px;
  }
  .about-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 3.5vw, 50px);
    font-weight: 900; line-height: 1.1;
    color: white; text-align: center; margin-bottom: 40px;
    letter-spacing: -0.02em;
  }
  .about-title .accent { color: var(--orange); font-style: italic; }

  .about-body {
    max-width: 760px; margin: 0 auto 64px;
    font-size: 17px; line-height: 1.8; color: rgba(255,255,255,0.75);
    text-align: center; font-weight: 300;
  }
  .about-body strong { color: white; font-weight: 700; }

  .pillars-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;
    max-width: 900px; margin: 0 auto;
  }
  .pillar {
    display: flex; flex-direction: column; align-items: center; text-align: center;
  }
  .pillar-icon-wrap {
    width: 88px; height: 88px; border-radius: 50%;
    background: var(--navy-mid);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px; flex-shrink: 0;
    font-size: 36px;
  }
  .pillar h4 {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 700; color: white;
    margin-bottom: 10px; line-height: 1.3;
  }
  .pillar p {
    font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.65;
  }

  /* ── CTA SECTION ── */
  .cta-section {
    background: var(--cream); padding: 96px 72px;
  }
  .cta-inner { max-width: 800px; margin: 0 auto; text-align: center; }
  .section-overline {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--orange); font-weight: 700; margin-bottom: 16px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(30px, 3.5vw, 46px); font-weight: 900;
    line-height: 1.1; color: var(--navy); margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .section-lead {
    font-size: 17px; line-height: 1.75; color: var(--text-mid);
    font-weight: 300; margin-bottom: 0;
  }

  .cta-cards {
    display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 48px;
  }

  .cta-card {
    display: block; text-decoration: none;
    border-radius: 16px; padding: 40px 36px;
    text-align: left; transition: all 0.25s;
    position: relative; overflow: hidden;
    cursor: pointer;
  }
  .cta-card.card-orange {
    background: var(--orange);
    box-shadow: 0 8px 32px rgba(224,90,43,0.3);
  }
  .cta-card.card-navy {
    background: var(--navy);
    box-shadow: 0 8px 32px rgba(27,43,75,0.25);
  }
  .cta-card:hover { transform: translateY(-5px); }
  .cta-card.card-orange:hover { box-shadow: 0 16px 48px rgba(224,90,43,0.45); }
  .cta-card.card-navy:hover { box-shadow: 0 16px 48px rgba(27,43,75,0.4); }

  /* decorative circle */
  .cta-card::after {
    content: '';
    position: absolute; top: -60px; right: -60px;
    width: 200px; height: 200px; border-radius: 50%;
    background: rgba(255,255,255,0.07);
    pointer-events: none;
  }

  .card-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.6); font-weight: 700; margin-bottom: 14px;
  }
  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 26px; font-weight: 900;
    color: white; margin-bottom: 12px; line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .card-desc {
    font-size: 14px; color: rgba(255,255,255,0.7);
    line-height: 1.7; margin-bottom: 28px; font-weight: 300;
  }
  .card-features {
    display: flex; flex-direction: column; gap: 8px; margin-bottom: 32px;
  }
  .card-feat {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: rgba(255,255,255,0.75); font-weight: 400;
  }
  .feat-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: rgba(255,255,255,0.5); flex-shrink: 0;
  }

  .card-btn {
    display: inline-flex; align-items: center; gap: 12px;
    background: rgba(255,255,255,0.15);
    border: 1.5px solid rgba(255,255,255,0.3);
    padding: 12px 24px; border-radius: 100px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; font-weight: 700;
    color: white; text-decoration: none;
    transition: all 0.2s;
  }
  .cta-card:hover .card-btn {
    background: rgba(255,255,255,0.25);
    border-color: rgba(255,255,255,0.5);
  }
  .card-btn-arrow {
    width: 8px; transition: transform 0.2s;
  }
  .cta-card:hover .card-btn-arrow { transform: translateX(4px); }

  /* ── PROCESS SECTION ── */
  .process-section { background: white; padding: 96px 72px; }

  .process-header { max-width: 580px; margin-bottom: 60px; }

  .process-steps {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 0;
    border: 1.5px solid rgba(27,43,75,0.1); border-radius: 12px; overflow: hidden;
  }
  .step {
    padding: 40px 32px;
    border-right: 1.5px solid rgba(27,43,75,0.1);
    position: relative;
  }
  .step:last-child { border-right: none; }

  .step-num {
    font-family: 'Playfair Display', serif;
    font-size: 48px; font-weight: 900;
    color: rgba(224,90,43,0.15); line-height: 1;
    margin-bottom: 16px; letter-spacing: -0.04em;
  }
  .step h4 {
    font-family: 'DM Sans', sans-serif;
    font-size: 17px; font-weight: 700; color: var(--navy);
    margin-bottom: 10px; line-height: 1.3;
  }
  .step p {
    font-size: 14px; color: var(--text-mid); line-height: 1.7;
  }

  /* ── TESTIMONIOS ── */
  .testimonios-section { background: var(--cream-mid); padding: 96px 72px; }

  .testimonios-header {
    text-align: center; max-width: 640px; margin: 0 auto 56px;
  }

  .t-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 16px;
    margin-bottom: 48px;
  }
  .t-card {
    background: white; border-radius: 12px; padding: 28px;
    border: 1px solid rgba(27,43,75,0.08);
    transition: all 0.22s;
  }
  .t-card:hover { box-shadow: 0 8px 28px rgba(27,43,75,0.1); transform: translateY(-3px); }
  .t-quote-mark {
    font-family: 'Playfair Display', serif;
    font-size: 48px; font-weight: 900; color: var(--orange);
    line-height: 0.7; margin-bottom: 16px; display: block;
  }
  .t-quote {
    font-family: 'DM Sans', sans-serif;
    font-style: italic; font-size: 14px; color: var(--text-dark);
    line-height: 1.7; margin-bottom: 20px; font-weight: 400;
  }
  .t-author-row {
    display: flex; align-items: center; gap: 10px;
    padding-top: 16px; border-top: 1px solid rgba(27,43,75,0.07);
  }
  .t-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--cream); display: flex; align-items: center;
    justify-content: center; font-size: 16px; flex-shrink: 0;
  }
  .t-name {
    font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 2px;
  }
  .t-from { font-size: 11px; color: var(--text-mid); }

  .t-soon {
    background: white; border-radius: 12px; padding: 28px;
    border: 2px dashed rgba(224,90,43,0.25);
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; text-align: center; gap: 12px;
  }
  .t-soon span { font-size: 28px; }
  .t-soon p {
    font-size: 14px; font-weight: 600; color: var(--orange-light); line-height: 1.5;
  }

  .testimonios-cta { display: flex; justify-content: center; }
  .btn-orange-outline {
    display: inline-flex; align-items: center; gap: 10px;
    background: transparent; color: var(--orange);
    border: 2px solid var(--orange);
    padding: 16px 36px; border-radius: 100px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px; font-weight: 700;
    text-decoration: none; transition: all 0.22s;
  }
  .btn-orange-outline:hover {
    background: var(--orange); color: white;
    box-shadow: 0 6px 24px rgba(224,90,43,0.35);
  }

  /* ── ALIADAS ── */
  .aliadas-section {
    background: var(--navy); padding: 80px 72px; text-align: center;
  }
  .aliadas-section .about-overline { margin-bottom: 16px; }
  .aliadas-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px,3vw,40px); font-weight: 900;
    color: white; margin-bottom: 16px; letter-spacing: -0.02em;
  }
  .aliadas-section p {
    font-size: 16px; color: rgba(255,255,255,0.6);
    max-width: 540px; margin: 0 auto 44px; line-height: 1.7; font-weight: 300;
  }
  .aliadas-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn-white {
    background: white; color: var(--navy);
    padding: 16px 36px; border-radius: 100px; border: none; cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px; font-weight: 700;
    text-decoration: none; display: inline-block;
    transition: all 0.22s;
  }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,0.2); }
  .btn-white-outline {
    background: transparent; color: white;
    border: 1.5px solid rgba(255,255,255,0.35);
    padding: 16px 36px; border-radius: 100px; cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px; font-weight: 600;
    text-decoration: none; display: inline-block;
    transition: all 0.22s;
  }
  .btn-white-outline:hover { border-color: white; background: rgba(255,255,255,0.08); }

  /* ── FOOTER ── */
  footer {
    background: #ffffff; padding: 52px 72px 32px;
    color: var(--text-mid);
    border-top: 1px solid rgba(27,43,75,0.1);
  }
  .footer-inner {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 40px; flex-wrap: wrap;
    padding-bottom: 36px; margin-bottom: 36px;
    border-bottom: 1px solid rgba(27,43,75,0.1);
  }
  .footer-brand-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 700; color: var(--orange);
    margin-bottom: 10px; line-height: 1.3;
  }
  .footer-brand p { font-size: 13px; line-height: 1.65; max-width: 280px; }
  .footer-col h5 {
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--text-mid); font-weight: 700; margin-bottom: 16px;
  }
  .footer-col a {
    display: block; font-size: 14px; color: var(--text-mid);
    text-decoration: none; margin-bottom: 10px; transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--navy); }
  .footer-bottom {
    display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
  }
  .footer-bottom p { font-size: 12px; color: var(--text-mid); }
  .hashtag {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px; font-weight: 700; color: var(--orange);
    letter-spacing: 0.04em;
  }


  /* Logo images */
  .nav-wgh-logo { height: 56px; width: auto; }
  .nav-brand-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; font-weight: 700; color: var(--orange);
    line-height: 1.2;
  }
  .wgh-logo-img { height: 220px; width: auto; max-width: 100%; }
  .wgh-name-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px; font-weight: 700; color: var(--text-mid);
    letter-spacing: 0.1em; text-transform: uppercase;
    margin-top: 2px;
  }
  .footer-wgh-logo { height: 200px; width: auto; max-width: 100%; margin-bottom: 16px; display: block; }

  /* ── CINCO SECTION ── */
  .cinco-section {
    background: var(--cream); padding: 96px 72px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;
  }
  .cinco-features { display: flex; flex-direction: column; gap: 12px; margin-top: 36px; }
  .cinco-feat {
    display: flex; gap: 16px; align-items: flex-start;
    background: white; border-radius: 8px; padding: 18px 20px;
    border-left: 3px solid var(--navy);
  }
  .cinco-feat-icon { font-size: 22px; flex-shrink: 0; margin-top: 1px; }
  .cinco-feat-title { font-weight: 700; color: var(--navy); font-size: 15px; margin-bottom: 3px; }
  .cinco-feat-desc { font-size: 13px; color: var(--text-mid); line-height: 1.5; }
  .cinco-privacy {
    margin-top: 20px; padding: 14px 18px;
    background: rgba(27,43,75,0.05); border-radius: 6px;
    font-size: 12px; color: var(--text-mid); line-height: 1.65;
  }
  .cinco-card {
    background: var(--navy); border-radius: 12px; padding: 36px;
    color: white; position: sticky; top: 96px;
  }
  .cinco-card-tag {
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--orange); font-weight: 700; margin-bottom: 12px;
  }
  .cinco-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 32px; font-weight: 900; line-height: 1.1;
    color: white; margin-bottom: 20px; letter-spacing: -0.02em;
  }
  .cinco-card-divider { height: 1px; background: rgba(255,255,255,0.12); margin-bottom: 20px; }
  .cinco-card-label {
    font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(255,255,255,0.4); font-weight: 600; display: block; margin-bottom: 6px;
  }
  .cinco-card-question {
    font-size: 15px; font-weight: 700; color: white; display: block; margin-bottom: 4px;
  }
  .cinco-card-sub { font-size: 12px; color: rgba(255,255,255,0.5); display: block; margin-bottom: 24px; }
  .cinco-card-btn {
    display: block; text-align: center; text-decoration: none;
    background: var(--orange); color: white;
    padding: 14px 24px; border-radius: 100px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px; font-weight: 700;
